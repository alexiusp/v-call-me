# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Generated by `flutter gen-l10n` (see l10n.yaml) - regenerated automatically
# on `flutter pub get` / `flutter run` / `flutter build` via `generate: true`.
/lib/l10n/generated/

# Real TURN/STUN API credentials - see lib/config/turn_config.example.dart
/lib/config/turn_config.dart

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Claude Code local settings (user-specific, not shared)
.claude/settings.local.json
